{
  "manifest_version": 3,
  "name": "Perplexity Finance Scraper Bridge",
  "version": "1.0",
  "description": "Bridges local Python scripts with authenticated Perplexity tabs to bypass Cloudflare.",
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "*://*.perplexity.ai/*",
    "*://*.trendlyne.com/*",
    "*://*.stockgro.club/*",
    "http://127.0.0.1:8778/*",
    "http://localhost:8778/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {},
  "content_scripts": [
    {
      "matches": ["*://*.perplexity.ai/*", "*://*.trendlyne.com/*", "*://*.stockgro.club/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
